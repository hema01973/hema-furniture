# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── MongoDB (Atlas replica set for transactions) ─────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/hema-furniture

# ─── NextAuth ─────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-char-random-secret-here

# ─── Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ─── Paymob (Egypt) ───────────────────────────────────
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=your-integration-id
PAYMOB_IFRAME_ID=your-iframe-id
PAYMOB_HMAC_SECRET=your-hmac-secret

# ─── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Hema Furniture <no-reply@hemafurniture.com>"
ADMIN_ALERT_EMAIL=admin@hemafurniture.com

# ─── Redis (required in production) ───────────────────
# Use TLS in production: rediss://password@hostname:port
REDIS_URL=redis://localhost:6379

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Admin seed ───────────────────────────────────────
ADMIN_EMAIL=admin@hemafurniture.com
ADMIN_PASSWORD=ChangeThisImmediately123!

# ─── Production Security Checklist ───────────────────
# □ Use AWS Secrets Manager / Doppler / Vercel for secrets
# □ Rotate NEXTAUTH_SECRET if ever exposed
# □ Redis must use rediss:// (TLS) in production
# □ Cloudinary: restrict API key to server IPs
# □ Paymob: set webhook IP whitelist in dashboard
# □ Set NEXTAUTH_URL to your production domain
